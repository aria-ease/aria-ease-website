{
  "meta": {
    "id": "docs.custom.contract.menu",
    "version": "1.0.0",
    "created": "11-02-2026",
    "lastUpdated": "19-03-2026",
    "description": "Simple fluent DSL example for menu custom policy",
    "source": {
      "apg": "https://www.w3.org/WAI/ARIA/apg/patterns/menubar/",
      "wcag": [
        "2.2 AA"
      ]
    },
    "W3CName": "Menu"
  },
  "selectors": {
    "main": "[aria-controls][aria-haspopup][aria-expanded]:not([role='menuitem']):not([role='menuitemcheckbox']):not([role='menuitemradio']), [aria-haspopup][aria-expanded]:not([role='menuitem']):not([role='menuitemcheckbox']):not([role='menuitemradio'])",
    "items": "[role=menuitem], [role=menuitemradio], [role=menuitemcheckbox]",
    "submenuTrigger": "[role=menu] [role=menuitem][aria-haspopup=true], [role=menu] [role=menuitemradio][aria-haspopup=true], [role=menu] [role=menuitemcheckbox][aria-haspopup=true], [role=menu] [role=menuitem][aria-haspopup=menu], [role=menu] [role=menuitemradio][aria-haspopup=menu], [role=menu] [role=menuitemcheckbox][aria-haspopup=menu]",
    "submenu": "[role=menu] [role=menu]",
    "submenuItems": "[role=menu] [role=menu] > [role=menuitem], [role=menu] [role=menu] > [role=menuitemradio], [role=menu] [role=menu] > [role=menuitemcheckbox]",
    "leafItem": "[role=menu] [role=menuitem]:not([aria-haspopup]), [role=menu] [role=menuitemradio]:not([aria-haspopup]), [role=menu] [role=menuitemcheckbox]:not([aria-haspopup])",
    "focusable": "[role=menuitem], [role=menuitemradio], [role=menuitemcheckbox]",
    "relative": "[role=menuitem], [role=menuitemradio], [role=menuitemcheckbox]",
    "popup": "[role=menu]"
  },
  "relationships": [
    {
      "type": "aria-reference",
      "from": "main",
      "attribute": "aria-controls",
      "to": "popup",
      "level": "required",
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        }
      ]
    },
    {
      "type": "aria-reference",
      "from": "popup",
      "attribute": "aria-labelledby",
      "to": "main",
      "level": "optional",
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        }
      ]
    },
    {
      "type": "contains",
      "parent": "popup",
      "child": "items",
      "level": "required",
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        }
      ]
    },
    {
      "type": "contains",
      "parent": "submenu",
      "child": "submenuItems",
      "level": "required",
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        },
        {
          "type": "keypress",
          "target": "submenuTrigger",
          "key": "ArrowRight"
        }
      ]
    }
  ],
  "static": [
    {
      "assertions": [
        {
          "target": "main",
          "attribute": "aria-haspopup",
          "expectedValue": "true | menu",
          "failureMessage": "",
          "level": "required"
        },
        {
          "target": "main",
          "attribute": "aria-expanded",
          "expectedValue": "false",
          "failureMessage": "",
          "level": "required"
        },
        {
          "target": "main",
          "attribute": "aria-controls",
          "expectedValue": "!empty",
          "failureMessage": "",
          "level": "required"
        },
        {
          "target": "popup",
          "attribute": "aria-labelledby",
          "expectedValue": "!empty",
          "failureMessage": "",
          "level": "optional",
          "setup": [
            {
              "type": "keypress",
              "target": "main",
              "key": "Enter"
            }
          ]
        },
        {
          "target": "popup",
          "attribute": "role",
          "expectedValue": "menu",
          "failureMessage": "",
          "level": "required",
          "setup": [
            {
              "type": "keypress",
              "target": "main",
              "key": "Enter"
            }
          ]
        },
        {
          "target": "items",
          "attribute": "role",
          "expectedValue": "menuitem | menuitemcheckbox | menuitemradio",
          "failureMessage": "",
          "level": "required",
          "setup": [
            {
              "type": "keypress",
              "target": "main",
              "key": "Enter"
            }
          ]
        },
        {
          "target": "items",
          "attribute": "tabindex",
          "expectedValue": "-1",
          "failureMessage": "",
          "level": "optional",
          "setup": [
            {
              "type": "keypress",
              "target": "main",
              "key": "Enter"
            }
          ]
        },
        {
          "target": "submenuTrigger",
          "attribute": "aria-haspopup",
          "expectedValue": "true | menu",
          "failureMessage": "",
          "level": "optional",
          "setup": [
            {
              "type": "keypress",
              "target": "main",
              "key": "Enter"
            },
            {
              "type": "keypress",
              "target": "submenuTrigger",
              "key": "ArrowRight"
            }
          ]
        }
      ]
    }
  ],
  "dynamic": [
    {
      "description": "Escape closes an open menu popup.",
      "level": "required",
      "action": [
        {
          "type": "keypress",
          "target": "items",
          "key": "Escape"
        }
      ],
      "assertions": [
        {
          "target": "popup",
          "assertion": "notToBeVisible",
          "failureMessage": "Expected popup to be closed"
        },
        {
          "target": "main",
          "assertion": "toHaveAttribute",
          "attribute": "aria-expanded",
          "expectedValue": "false",
          "failureMessage": "Expect menu main to have aria-expanded='false'."
        }
      ],
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        }
      ]
    },
    {
      "description": "Click on a menu button when menu closed opens the menu popup.",
      "level": "required",
      "action": [
        {
          "type": "click",
          "target": "main"
        }
      ],
      "assertions": [
        {
          "target": "popup",
          "assertion": "toBeVisible",
          "failureMessage": "Expected popup to be visible"
        },
        {
          "target": "main",
          "assertion": "toHaveAttribute",
          "attribute": "aria-expanded",
          "expectedValue": "true",
          "failureMessage": "Expect menu main to have aria-expanded='true'."
        }
      ]
    },
    {
      "description": "Click on a menu button when menu open closes the menu popup.",
      "level": "required",
      "action": [
        {
          "type": "click",
          "target": "main"
        }
      ],
      "assertions": [
        {
          "target": "popup",
          "assertion": "notToBeVisible",
          "failureMessage": "Expected popup to be closed"
        },
        {
          "target": "main",
          "assertion": "toHaveAttribute",
          "attribute": "aria-expanded",
          "expectedValue": "false",
          "failureMessage": "Expect menu main to have aria-expanded='false'."
        }
      ],
      "setup": [
        {
          "type": "click",
          "target": "main"
        }
      ]
    },
    {
      "description": "Enter on a menu item closes an open menu popup.",
      "level": "required",
      "action": [
        {
          "type": "keypress",
          "target": "items",
          "key": "Enter"
        }
      ],
      "assertions": [
        {
          "target": "popup",
          "assertion": "notToBeVisible",
          "failureMessage": "Expected popup to be closed"
        },
        {
          "target": "main",
          "assertion": "toHaveAttribute",
          "attribute": "aria-expanded",
          "expectedValue": "false",
          "failureMessage": "Expect menu main to have aria-expanded='false'."
        }
      ],
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        }
      ]
    },
    {
      "description": "Space on a menu item closes an open menu popup.",
      "level": "required",
      "action": [
        {
          "type": "keypress",
          "target": "items",
          "key": "Space"
        }
      ],
      "assertions": [
        {
          "target": "popup",
          "assertion": "notToBeVisible",
          "failureMessage": "Expected popup to be closed"
        },
        {
          "target": "main",
          "assertion": "toHaveAttribute",
          "attribute": "aria-expanded",
          "expectedValue": "false",
          "failureMessage": "Expect menu main to have aria-expanded='false'."
        }
      ],
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        }
      ]
    },
    {
      "description": "ArrowDown on a menu item moves focus to the next menu item when the menu popup is open.",
      "level": "required",
      "action": [
        {
          "type": "keypress",
          "target": "items",
          "key": "ArrowDown"
        }
      ],
      "assertions": [],
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        }
      ]
    },
    {
      "description": "ArrowUp on a menu item moves focus to the previous menu item when the menu popup is open.",
      "level": "required",
      "action": [
        {
          "type": "keypress",
          "target": "items",
          "key": "ArrowUp"
        }
      ],
      "assertions": [
        {
          "target": "relative",
          "assertion": "toHaveFocus",
          "expectedValue": "last",
          "failureMessage": "Last menu item should have focus."
        }
      ],
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        }
      ]
    },
    {
      "description": "Home on a menu item moves focus to the first menu item when the menu popup is open.",
      "level": "required",
      "action": [
        {
          "type": "keypress",
          "target": "items",
          "key": "Home"
        }
      ],
      "assertions": [
        {
          "target": "relative",
          "assertion": "toHaveFocus",
          "expectedValue": "first",
          "failureMessage": "First menu item should have focus."
        }
      ],
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        }
      ]
    },
    {
      "description": "End on a menu item moves focus to the last menu item when the menu popup is open.",
      "level": "required",
      "action": [
        {
          "type": "keypress",
          "target": "items",
          "key": "End"
        }
      ],
      "assertions": [
        {
          "target": "relative",
          "assertion": "toHaveFocus",
          "expectedValue": "last",
          "failureMessage": "Last menu item should have focus."
        }
      ],
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        }
      ]
    },
    {
      "description": "Tab on a menu item closes an open menu popup and moves focus to the next focusable element in the tab order after the menu.",
      "level": "required",
      "action": [
        {
          "type": "keypress",
          "target": "items",
          "key": "Tab"
        }
      ],
      "assertions": [
        {
          "target": "popup",
          "assertion": "notToBeVisible",
          "failureMessage": "Expected popup to be closed"
        },
        {
          "target": "main",
          "assertion": "toHaveAttribute",
          "attribute": "aria-expanded",
          "expectedValue": "false",
          "failureMessage": "Expect menu main to have aria-expanded='false'."
        },
        {
          "target": "main",
          "assertion": "notToHaveFocus",
          "failureMessage": "Expected menu main to not have focused."
        }
      ],
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        }
      ]
    },
    {
      "description": "ArrowRight on a menu item with a submenu opens the submenu and moves focus to the first item when the menu popup is open.",
      "level": "required",
      "action": [
        {
          "type": "keypress",
          "target": "submenuTrigger",
          "key": "ArrowRight"
        }
      ],
      "assertions": [
        {
          "target": "submenuItems",
          "assertion": "toHaveFocus",
          "failureMessage": "First interactive item in the submenu should have focus after Right Arrow open the submenu."
        }
      ],
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        }
      ]
    },
    {
      "description": "ArrowLeft on a submenu item closes the submenu and moves focus to the submenu trigger.",
      "level": "required",
      "action": [
        {
          "type": "keypress",
          "target": "submenuItems",
          "key": "ArrowLeft"
        }
      ],
      "assertions": [
        {
          "target": "submenu",
          "assertion": "notToBeVisible",
          "failureMessage": "Expected submenu to be closed"
        },
        {
          "target": "submenuTrigger",
          "assertion": "toHaveAttribute",
          "attribute": "aria-expanded",
          "expectedValue": "false",
          "failureMessage": "Expect submenu trigger to have aria-expanded='false'."
        },
        {
          "target": "submenuTrigger",
          "assertion": "toHaveFocus",
          "failureMessage": "Expected submenu trigger to be focused."
        }
      ],
      "setup": [
        {
          "type": "keypress",
          "target": "main",
          "key": "Enter"
        },
        {
          "type": "keypress",
          "target": "submenuTrigger",
          "key": "ArrowRight"
        }
      ]
    }
  ]
}
